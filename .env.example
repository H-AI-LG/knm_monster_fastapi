ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173","https://knm.ai.kr"]

# PostgreSQL (로컬: docker compose up)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knm

# AWS Bedrock API 키 방식 (Bedrock 콘솔 > API 키 > 단기/장기 API 키 생성)
AWS_REGION=ap-northeast-2
AI_MODEL=claude-3-5-haiku-20241022
BEDROCK_API_KEY=your_bedrock_api_key_here
