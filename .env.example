ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173","https://knm.ai.kr"]

# PostgreSQL (로컬: docker-compose up)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knm

# AWS Bedrock (자격증명은 기존 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 재사용)
# ECS 배포 시에는 IAM Role로 자동 주입 — 별도 키 불필요
AWS_REGION=us-east-1
AI_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
